{
  "name": "actions-setup-cmake",
  "version": "1.0.0",
  "description": "GitHub action to setup cmake",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jwlawson/actions-setup-cmake"
  },
  "scripts": {
    "package": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --minify --outfile=dist/index.js",
    "format": "prettier --write **/*.ts",
    "prepare": "pnpm run format && pnpm run package",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "keywords": [
    "cmake",
    "action",
    "setup"
  ],
  "author": "John Lawson",
  "license": "BSD-3-Clause-Clear",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.4",
    "typed-rest-client": "^2.3.0"
  },
  "devDependencies": {
    "@actions/github": "^9.1.1",
    "@actions/io": "^3.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.1",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "nock": "^14.0.13",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [".ts"],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "husky": {
    "skipCI": true,
    "hooks": {
      "pre-commit": "pnpm run prepare && git add dist/"
    }
  },
  "prettier": {
    "arrowParens": "always",
    "printWidth": 80,
    "singleQuote": true,
    "tabWidth": 2,
    "useTabs": false
  }
}
